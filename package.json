{
  "name": "app",
  "type": "module",
  "version": "1.2.1",
  "homepage": "https://ht.apollogeddon.com",
  "scripts": {
    "dev": "astro dev",
    "type": "astro sync && tsc --noEmit --ignoreDeprecations 5.0",
    "lint:ts": "biome check --fix",
    "lint:md": "markdownlint-cli2 --fix",
    "lint": "biome check --fix && npm run lint:md",
    "build": "astro build",
    "preview": "astro preview",
    "pretest": "playwright install --with-deps",
    "test": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "security": "osv-scanner scan -r .",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@apollogeddon/forgejs": "2.1.1",
    "@astrojs/react": "^5.0.5",
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.3.7",
    "markdownlint-cli2": "^0.22.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.1.18"
  },
  "private": true,
  "overrides": {
    "vite": "7.3.3"
  }
}
