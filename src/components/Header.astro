---
import { Image } from "astro:assets";
import logoImage from "../assets/logo.png";
import { NAVIGATION, ROUTES, SITE_TITLE } from "../consts";
import ThemeToggle from "./Themes.astro";
---

<header
  class="border-b sticky top-0 z-50 backdrop-blur-md transition-colors duration-300"
  style={{ backgroundColor: "var(--header-bg)", borderColor: "var(--header-border)" }}
>
  <div class="container mx-auto px-4 py-4 flex justify-between items-center">
    <a href={ROUTES.HOME} class="flex items-center">
      <Image src={logoImage} alt={SITE_TITLE} class="h-12 w-auto" width={200} height={48} loading="eager" />
    </a>
    <div class="flex items-center">
      <nav class="hidden md:block" aria-label="Main navigation">
        <ul class="flex space-x-8">
          {
            NAVIGATION.map((item) => {
              const pathname = Astro.url.pathname.replace(/\/$/, "");
              const href = item.href.replace(/\/$/, "");
              const isActive = pathname === href || (href !== "" && pathname.startsWith(href));

              return (
                <li>
                  <a
                    href={item.href}
                    class={`relative font-medium transition-colors duration-200 pb-1 ${
                      isActive
                        ? "text-[var(--brand-accent)] font-bold border-b-2 border-[var(--brand-accent)]"
                        : "text-[var(--text-secondary)] hover:text-[var(--text-primary)]"
                    }`}
                  >
                    {item.label}
                  </a>
                </li>
              );
            })
          }
        </ul>
      </nav>

      <button
        id="mobile-menu-open"
        class="md:hidden p-2 text-[var(--text-secondary)] hover:text-[var(--brand-accent)] transition-colors"
        aria-label="Open Menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
        </svg>
      </button>

      <div class="ml-2 border-l pl-2 md:ml-4 md:pl-4" style={{ borderColor: "var(--header-border)" }}>
        <ThemeToggle />
      </div>
    </div>
  </div>
</header>

<div
  id="mobile-menu"
  inert
  class="fixed inset-0 z-[100] bg-[var(--brand-accent)] flex flex-col items-center justify-center space-y-8 transition-transform duration-300 translate-x-full"
>
  <button
    id="mobile-menu-close"
    class="absolute top-6 right-6 p-2 text-white hover:opacity-70 transition-opacity"
    aria-label="Close Menu"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <nav>
    <ul class="flex flex-col items-center space-y-6">
      {
        NAVIGATION.map((item) => (
          <li>
            <a href={item.href} class="text-2xl font-bold text-white hover:opacity-80 transition-opacity">
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

</div>

<script>
  const initMobileMenu = () => {
    const openBtn = document.getElementById("mobile-menu-open");
    const closeBtn = document.getElementById("mobile-menu-close");
    const menu = document.getElementById("mobile-menu");

    if (!openBtn || !closeBtn || !menu) return;

    const toggleMenu = (show: boolean) => {
      if (show) {
        menu.classList.remove("translate-x-full");
        menu.classList.add("translate-x-0");
        menu.removeAttribute("inert");
        document.body.style.overflow = "hidden";
      } else {
        menu.classList.add("translate-x-full");
        menu.classList.remove("translate-x-0");
        menu.setAttribute("inert", "");
        document.body.style.overflow = "";
      }
    };

    openBtn.addEventListener("click", () => toggleMenu(true));
    closeBtn.addEventListener("click", () => toggleMenu(false));

    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => toggleMenu(false));
    });
  };

  document.addEventListener("astro:page-load", initMobileMenu);
</script>
