---
interface Props {
  variant?: "growth" | "people" | "strategy";
}

const { variant = "people" } = Astro.props;
---

<div
  aria-hidden="true"
  class="relative w-full aspect-square max-w-md mx-auto overflow-hidden rounded-3xl select-none"
>
  <div
    class="absolute inset-0"
    style="background: radial-gradient(ellipse at 30% 40%, rgba(242,139,60,0.18) 0%, transparent 60%), radial-gradient(ellipse at 70% 70%, rgba(180,83,9,0.13) 0%, transparent 55%);"
  ></div>

  <div
    class="absolute"
    style="width: 65%; height: 65%; top: -10%; left: -10%; background: linear-gradient(135deg, rgba(242,139,60,0.15), rgba(180,83,9,0.08)); border-radius: 60% 40% 70% 30% / 50% 60% 40% 55%; filter: blur(2px);"
  ></div>

  <div
    class="absolute"
    style="width: 55%; height: 55%; bottom: -8%; right: -8%; background: linear-gradient(225deg, rgba(249,181,120,0.12), rgba(242,139,60,0.18)); border-radius: 40% 60% 30% 70% / 55% 40% 60% 45%; filter: blur(3px);"
  ></div>

  <div class="absolute inset-0 flex items-center justify-center p-10">
    {
      variant === "people" && (
        <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full opacity-70">
          <circle cx="100" cy="60" r="22" stroke="currentColor" stroke-width="3" class="text-[var(--brand-accent)]" />
          <circle cx="50" cy="130" r="18" stroke="currentColor" stroke-width="3" class="text-[var(--brand-accent)]" />
          <circle cx="150" cy="130" r="18" stroke="currentColor" stroke-width="3" class="text-[var(--brand-accent)]" />
          <circle cx="100" cy="155" r="18" stroke="currentColor" stroke-width="3" class="text-[var(--color-brand-300)]" />
          <line x1="100" y1="82" x2="60" y2="115" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" class="text-[var(--color-brand-300)]" />
          <line x1="100" y1="82" x2="140" y2="115" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" class="text-[var(--color-brand-300)]" />
          <line x1="100" y1="82" x2="100" y2="137" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" class="text-[var(--color-brand-300)]" />
        </svg>
      )
    }
    {
      variant === "growth" && (
        <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full opacity-70">
          <line x1="20" y1="180" x2="20" y2="30" stroke="currentColor" stroke-width="3" stroke-linecap="round" class="text-[var(--border-strong)]" />
          <line x1="20" y1="180" x2="185" y2="180" stroke="currentColor" stroke-width="3" stroke-linecap="round" class="text-[var(--border-strong)]" />
          <polyline points="30,150 65,120 95,130 130,85 160,60 185,35" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--brand-accent)]" fill="none" />
          <circle cx="30" cy="150" r="5" fill="currentColor" class="text-[var(--brand-accent)]" />
          <circle cx="65" cy="120" r="5" fill="currentColor" class="text-[var(--brand-accent)]" />
          <circle cx="95" cy="130" r="5" fill="currentColor" class="text-[var(--brand-accent)]" />
          <circle cx="130" cy="85" r="5" fill="currentColor" class="text-[var(--brand-accent)]" />
          <circle cx="160" cy="60" r="5" fill="currentColor" class="text-[var(--brand-accent)]" />
          <circle cx="185" cy="35" r="5" fill="currentColor" class="text-[var(--color-brand-300)]" />
        </svg>
      )
    }
    {
      variant === "strategy" && (
        <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full opacity-70">
          <circle cx="100" cy="100" r="75" stroke="currentColor" stroke-width="2.5" class="text-[var(--border-strong)]" />
          <circle cx="100" cy="100" r="50" stroke="currentColor" stroke-width="2.5" class="text-[var(--color-brand-300)]" />
          <circle cx="100" cy="100" r="25" stroke="currentColor" stroke-width="2.5" class="text-[var(--brand-accent)]" />
          <circle cx="100" cy="100" r="7" fill="currentColor" class="text-[var(--brand-accent)]" />
          <line x1="100" y1="25" x2="100" y2="175" stroke="currentColor" stroke-width="1.5" stroke-dasharray="4 4" class="text-[var(--border-subtle)]" />
          <line x1="25" y1="100" x2="175" y2="100" stroke="currentColor" stroke-width="1.5" stroke-dasharray="4 4" class="text-[var(--border-subtle)]" />
        </svg>
      )
    }
  </div>
</div>
