---
import Button from "./Button.astro";

interface Props {
  title: string;
  description: string;
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const { title, description, primaryLabel, primaryHref, secondaryLabel, secondaryHref } = Astro.props;
---

<section class="section-padding">
  <div class="container-site">
    <div class="bg-brand-gradient rounded-3xl px-8 py-16 lg:px-16 lg:py-20 text-center">
      <h2 class="text-3xl lg:text-4xl font-extrabold text-white mb-4 leading-tight">{title}</h2>
      <p class="text-white/85 text-lg mb-10 max-w-2xl mx-auto leading-relaxed">{description}</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <Button href={primaryHref} label={primaryLabel} variant="onDark" />
        {secondaryLabel && secondaryHref && (
          <Button href={secondaryHref} label={secondaryLabel} variant="onDarkSecondary" />
        )}
      </div>
    </div>
  </div>
</section>
