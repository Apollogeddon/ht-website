---
interface Props {
  orgs: string[];
}

const { orgs } = Astro.props;
---

<div class="border-b py-6" style={{ borderColor: "var(--border-subtle)" }}>
  <div class="container-site">
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-6 text-center">
      <p class="text-sm font-semibold text-[var(--text-secondary)] whitespace-nowrap uppercase tracking-wide">
        Trusted by:
      </p>
      <span
        class="trusted-by-pill text-sm font-medium px-4 py-1.5 rounded-full border transition-opacity duration-300"
        style={{ borderColor: "var(--border-subtle)", color: "var(--text-primary)", backgroundColor: "var(--bg-secondary)" }}
        data-orgs={JSON.stringify(orgs)}
      >
        {orgs[0]}
      </span>
    </div>
  </div>
</div>

<script>
  const initTrustedBy = () => {
    document.querySelectorAll<HTMLElement>(".trusted-by-pill").forEach((pill) => {
      const orgs: string[] = JSON.parse(pill.dataset.orgs ?? "[]");
      if (orgs.length <= 1) return;
      let i = 0;
      setInterval(() => {
        pill.style.opacity = "0";
        setTimeout(() => {
          i = (i + 1) % orgs.length;
          pill.textContent = orgs[i];
          pill.style.opacity = "1";
        }, 300);
      }, 3000);
    });
  };

  document.addEventListener("astro:page-load", initTrustedBy);
</script>
