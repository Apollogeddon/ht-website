---
interface Props {
  orgs: string[];
}

const { orgs } = Astro.props;
---

<div class="border-b py-6" style={{ borderColor: "var(--border-subtle)" }}>
  <div class="container-site">
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-6 text-center">
      <p class="text-sm font-semibold text-[var(--text-secondary)] whitespace-nowrap uppercase tracking-wide">
        Trusted by:
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        {
          orgs.map((org) => (
            <span
              class="text-sm font-medium px-4 py-1.5 rounded-full border"
              style={{ borderColor: "var(--border-subtle)", color: "var(--text-primary)", backgroundColor: "var(--bg-secondary)" }}
            >
              {org}
            </span>
          ))
        }
        <span class="text-sm text-[var(--text-secondary)]">and 200+ organisations across Australia</span>
      </div>
    </div>
  </div>
</div>
