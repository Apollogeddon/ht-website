---
import {
  BLOG_CONTENT,
  CONTACT_INFO,
  CONTACT_PAGE,
  FOOTER_SECTIONS,
  NAVIGATION,
  POLICIES_CONTENT,
  ROUTES,
  SITE_DESCRIPTION,
  SITE_TITLE,
} from "../consts";

const currentYear = new Date().getFullYear();
---

<footer class="bg-[var(--bg-muted)] text-[var(--text-secondary)] border-t border-[var(--border-subtle)] transition-colors duration-300">
  <div class="h-[3px] bg-brand-gradient w-full"></div>
  <div class="container mx-auto px-6 lg:px-12 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <div>
        <p class="text-lg font-bold mb-4 text-gradient-brand">{SITE_TITLE}</p>
        <p class="text-[var(--text-secondary)] text-sm leading-relaxed">
          {SITE_DESCRIPTION}
        </p>
      </div>

      <div>
        <p class="text-lg font-bold mb-4 text-[var(--text-primary)]">{FOOTER_SECTIONS.contact}</p>
        <ul class="text-[var(--text-secondary)] text-sm space-y-2">
          <li>{CONTACT_PAGE.labels.email}: {CONTACT_INFO.email}</li>
          <li>{CONTACT_PAGE.labels.phone}: {CONTACT_INFO.phone}</li>
          <li>{CONTACT_PAGE.labels.location}: {CONTACT_INFO.location}</li>
        </ul>
      </div>

      <div>
        <p class="text-lg font-bold mb-4 text-[var(--text-primary)]">{FOOTER_SECTIONS.services}</p>
        <ul class="text-[var(--text-secondary)] text-sm space-y-2">
          <li><a href={NAVIGATION[1].href} class="hover:text-[var(--brand-accent)] transition-colors">{NAVIGATION[1].label}</a></li>
          <li><a href={NAVIGATION[2].href} class="hover:text-[var(--brand-accent)] transition-colors">{NAVIGATION[2].label}</a></li>
          <li><a href={NAVIGATION[3].href} class="hover:text-[var(--brand-accent)] transition-colors">{NAVIGATION[3].label}</a></li>
        </ul>
      </div>

      <div>
        <p class="text-lg font-bold mb-4 text-[var(--text-primary)]">{FOOTER_SECTIONS.company}</p>
        <ul class="text-[var(--text-secondary)] text-sm space-y-2">
          <li><a href={NAVIGATION[4].href} class="hover:text-[var(--brand-accent)] transition-colors">{NAVIGATION[4].label}</a></li>
          <li><a href={ROUTES.CONTACT} class="hover:text-[var(--brand-accent)] transition-colors">{CONTACT_PAGE.title}</a></li>
          <li><a href={ROUTES.POLICIES} class="hover:text-[var(--brand-accent)] transition-colors">{POLICIES_CONTENT.title}</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-[var(--border-subtle)] mt-12 pt-8 text-center text-[var(--text-secondary)] text-sm opacity-80">
      <p>&copy; {currentYear} {SITE_TITLE}. {FOOTER_SECTIONS.copyright}</p>
    </div>
  </div>
</footer>
