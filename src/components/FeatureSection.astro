---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import IllustrationPanel from "./IllustrationPanel.astro";
import SectionHeading from "./SectionHeading.astro";

interface Props {
  eyebrow?: string;
  title: string;
  paragraphs: string[];
  quote?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  imageSrc?: ImageMetadata;
  imageAlt?: string;
  reverse?: boolean;
  muted?: boolean;
  level?: 1 | 2;
}

const {
  eyebrow,
  title,
  paragraphs,
  quote,
  primaryLabel,
  primaryHref,
  secondaryLabel,
  secondaryHref,
  imageSrc,
  imageAlt = "",
  reverse = false,
  muted = false,
  level,
} = Astro.props;
---

<section class={`section-padding scroll-reveal ${muted ? "bg-[var(--bg-muted)]" : "bg-[var(--bg-secondary)]"}`}>
  <div class="container-site">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class={reverse ? "lg:order-2" : ""}>
        <SectionHeading eyebrow={eyebrow} title={title} level={level} />
        <div class="mt-6 space-y-4">
          {paragraphs.map((paragraph) => (
            <p class="text-lg text-[var(--text-secondary)] leading-relaxed">{paragraph}</p>
          ))}
        </div>
        {
          quote && (
            <div class="mt-8 border-l-4 border-[var(--brand-accent)] pl-6 italic text-[var(--text-secondary)]">
              "{quote}"
            </div>
          )
        }
        {
          primaryLabel && primaryHref && (
            <div class="mt-8 flex flex-wrap gap-4">
              <a
                href={primaryHref}
                class="inline-flex items-center gap-2 bg-[var(--brand-accent)] text-white font-bold px-8 py-4 rounded-xl transition-all duration-200 hover:bg-[var(--brand-accent-hover)] hover:-translate-y-0.5 hover:shadow-md"
              >
                {primaryLabel}
              </a>
              {secondaryLabel && secondaryHref && (
                <a
                  href={secondaryHref}
                  class="inline-flex items-center gap-2 border-2 border-[var(--brand-accent)] text-[var(--brand-accent)] font-bold px-8 py-4 rounded-xl transition-all duration-200 hover:bg-[var(--brand-light)]"
                >
                  {secondaryLabel}
                </a>
              )}
            </div>
          )
        }
      </div>
      <div class={reverse ? "lg:order-1" : ""}>
        {imageSrc ? (
          <Image
            src={imageSrc}
            alt={imageAlt}
            class="rounded-2xl shadow-lg w-full object-cover aspect-[4/3]"
          />
        ) : (
          <IllustrationPanel variant="growth" />
        )}
      </div>
    </div>
  </div>
</section>
