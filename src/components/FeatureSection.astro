---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import Button from "./Button.astro";
import IllustrationPanel from "./IllustrationPanel.astro";
import SectionHeading from "./SectionHeading.astro";

interface Props {
  eyebrow?: string;
  title: string;
  paragraphs: string[];
  quote?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  imageSrc?: ImageMetadata;
  imageAlt?: string;
  reverse?: boolean;
  muted?: boolean;
  level?: 1 | 2;
  illustrationVariant?: "growth" | "people" | "strategy";
}

const {
  eyebrow,
  title,
  paragraphs,
  quote,
  primaryLabel,
  primaryHref,
  secondaryLabel,
  secondaryHref,
  imageSrc,
  imageAlt = "",
  reverse = false,
  muted = false,
  level,
  illustrationVariant = "growth",
} = Astro.props;
---

<section class={`section-padding scroll-reveal ${muted ? "bg-[var(--bg-muted)]" : "bg-[var(--bg-secondary)]"}`}>
  <div class="container-site">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class={reverse ? "lg:order-2" : ""}>
        <SectionHeading eyebrow={eyebrow} title={title} level={level} />
        <div class="mt-6 space-y-4">
          {paragraphs.map((paragraph) => (
            <p class="text-lg text-[var(--text-secondary)] leading-relaxed">{paragraph}</p>
          ))}
        </div>
        {
          quote && (
            <div class="mt-8 border-l-4 border-[var(--brand-accent)] pl-6 italic text-[var(--text-secondary)]">
              "{quote}"
            </div>
          )
        }
        {
          primaryLabel && primaryHref && (
            <div class="mt-8 flex flex-wrap gap-4">
              <Button href={primaryHref} label={primaryLabel} variant="primary" />
              {secondaryLabel && secondaryHref && (
                <Button href={secondaryHref} label={secondaryLabel} variant="secondary" />
              )}
            </div>
          )
        }
      </div>
      <div class={reverse ? "lg:order-1" : ""}>
        {imageSrc ? (
          <Image
            src={imageSrc}
            alt={imageAlt}
            class="rounded-2xl shadow-lg w-full object-cover aspect-[4/3]"
          />
        ) : (
          <IllustrationPanel variant={illustrationVariant} />
        )}
      </div>
    </div>
  </div>
</section>
