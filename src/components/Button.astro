---
interface Props {
  href: string;
  label: string;
  variant?: "primary" | "secondary" | "onDark" | "onDarkSecondary";
}

const { href, label, variant = "primary" } = Astro.props;

const variantClasses: Record<string, string> = {
  primary:
    "bg-[var(--brand-accent)] text-white hover:bg-[var(--brand-accent-hover)] hover:-translate-y-0.5 hover:shadow-md",
  secondary: "border-2 border-[var(--brand-accent)] text-[var(--brand-accent)] hover:bg-[var(--brand-light)]",
  onDark:
    "bg-white text-[var(--color-brand-600)] hover:bg-[var(--color-brand-50)] hover:shadow-lg hover:-translate-y-0.5",
  onDarkSecondary: "bg-transparent text-white border-2 border-white/70 hover:bg-white/10 hover:border-white",
};
---

<a
  href={href}
  class={`inline-flex items-center gap-2 font-bold px-8 py-4 rounded-xl transition-all duration-200 ${variantClasses[variant]}`}
>
  {label}
</a>
