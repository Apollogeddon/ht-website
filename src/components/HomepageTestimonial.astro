---
import Quote from "./Quote.astro";

interface Props {
  quote: string;
  author: string;
  role: string;
}

const { quote, author, role } = Astro.props;
---

<section class="section-padding-sm bg-[var(--brand-accent)]">
  <div class="container-site">
    <Quote text={quote} author={author} role={role} variant="hero" />
  </div>
</section>
