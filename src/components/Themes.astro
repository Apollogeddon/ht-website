---
import { ICONS } from "../styles";
---

<button
  type="button"
  class="theme-toggle-btn text-[var(--text-secondary)] hover:text-[var(--brand-accent)] focus:outline-none rounded-lg text-sm p-2.5 ml-4 transition-all duration-300"
  aria-label="Toggle Dark Mode"
  aria-pressed="false"
>
  <span class="toggle-icon block transition-transform duration-300">
    <svg
      class="sun-icon w-6 h-6 text-[var(--brand-accent)]"
      viewBox="0 0 20 20"
      fill="currentColor"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path d={ICONS.sun} fill-rule="evenodd" clip-rule="evenodd"></path>
    </svg>

    <svg
      class="moon-icon w-6 h-6 text-[var(--text-secondary)]"
      viewBox="0 0 20 20"
      fill="currentColor"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path d={ICONS.moon}></path>
    </svg>
  </span>
</button>

<style>
  .sun-icon { display: none; }
  .moon-icon { display: block; }

  :global(html.dark) .sun-icon { display: block; }
  :global(html.dark) .moon-icon { display: none; }

  :global(html.dark) .toggle-icon { transform: rotate(180deg); }
</style>

