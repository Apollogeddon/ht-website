---
import type { CollectionEntry } from "astro:content";
import { DATE_LOCALE, DATE_OPTIONS, ROUTES, UI_LABELS } from "../consts";

interface Props {
  posts: CollectionEntry<"blog">[];
}

const { posts } = Astro.props;
---

{
  posts.length > 0 && (
    <section class="section-padding">
      <div class="container-site">
        <div class="text-center mb-10">
          <span class="eyebrow">From the Blog</span>
          <h2 class="mt-3 text-2xl lg:text-3xl font-bold text-[var(--text-primary)]">
            Our Latest Information & Resources
          </h2>
        </div>
        <div class={`grid grid-cols-1 gap-6 ${posts.length > 1 ? "md:grid-cols-2" : ""}`}>
          {posts.map((post) => (
            <a href={`${ROUTES.BLOG}/${post.id}`} class="card-interactive p-6 block group">
              <time class="text-xs text-[var(--text-secondary)] font-medium uppercase tracking-wide">
                {new Date(post.data.pubDate).toLocaleDateString(DATE_LOCALE, DATE_OPTIONS)}
              </time>
              <h3 class="mt-2 font-bold text-[var(--text-primary)] group-hover:text-[var(--brand-accent)] transition-colors">
                {post.data.title}
              </h3>
              <p class="mt-2 text-sm text-[var(--text-secondary)] line-clamp-2">{post.data.description}</p>
              <span class="mt-3 inline-block text-sm font-medium text-[var(--brand-accent)]">
                {UI_LABELS.readMore} →
              </span>
            </a>
          ))}
        </div>
        <div class="text-center mt-8">
          <a href={ROUTES.BLOG} class="btn-secondary">View all posts</a>
        </div>
      </div>
    </section>
  )
}
