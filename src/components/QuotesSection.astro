---
import geoBg from "../assets/external/geometic-bg-white-2.jpg";
import Quote from "./Quote.astro";

interface QuoteItem {
  text: string;
  author: string;
}

interface Props {
  quotes: QuoteItem[];
}

const { quotes } = Astro.props;
---

<section
  class="section-padding-sm relative overflow-hidden bg-[var(--bg-muted)]"
  style={`background-image: url(${geoBg.src}); background-size: cover; background-position: center;`}
>
  <div class="absolute inset-0 bg-[var(--bg-primary)] opacity-90 dark:opacity-95"></div>
  <div class="container-site relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {quotes.map((q) => (
        <Quote text={q.text} author={q.author} variant="grid" />
      ))}
    </div>
  </div>
</section>
