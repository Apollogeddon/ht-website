---
interface Quote {
  text: string;
  author: string;
}

interface Props {
  quotes: Quote[];
}

const { quotes } = Astro.props;
---

<section class="section-padding-sm bg-[var(--bg-muted)]">
  <div class="container-site">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {
        quotes.map((q) => (
          <blockquote class="card-base p-6 flex flex-col gap-3">
            <svg
              class="h-6 w-6 text-[var(--brand-accent)] flex-shrink-0"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
            </svg>
            <p class="text-[var(--text-secondary)] italic leading-relaxed flex-1">{q.text}</p>
            <footer class="text-sm font-semibold text-[var(--brand-accent)]">— {q.author}</footer>
          </blockquote>
        ))
      }
    </div>
  </div>
</section>
