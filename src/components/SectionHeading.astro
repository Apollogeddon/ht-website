---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
  level?: 1 | 2;
}

const { eyebrow, title, description, align = "left", level = 2 } = Astro.props;
const centered = align === "center";
const headingClass = "text-3xl lg:text-4xl font-bold text-[var(--text-primary)] leading-tight mb-4";
---

<div class={centered ? "text-center" : ""}>
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  {level === 1
    ? <h1 class={headingClass}>{title}</h1>
    : <h2 class={headingClass}>{title}</h2>
  }
  {
    description && (
      <p class={`text-lg text-[var(--text-secondary)] leading-relaxed${centered ? " max-w-2xl mx-auto" : " max-w-2xl"}`}>
        {description}
      </p>
    )
  }
</div>
