---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  height?: "sm" | "md";
  overlayOpacity?: "30" | "40";
}

const { src, alt, height = "sm", overlayOpacity = "40" } = Astro.props;

const heightClasses = { sm: "h-52 md:h-64", md: "h-56 md:h-72" } as const;
const overlayClasses = { "30": "opacity-30", "40": "opacity-40" } as const;
---

<div class={`relative ${heightClasses[height]} overflow-hidden`}>
  <Image
    src={src}
    alt={alt}
    class="w-full h-full object-cover object-center"
    widths={[640, 1280, 1920]}
    sizes="100vw"
  />
  <div class={`absolute inset-0 bg-[var(--bg-inverse)] ${overlayClasses[overlayOpacity]}`}></div>
</div>
