---
import marketingStrategy from "../assets/external/marketing-board-strategy.jpg";
import meetingCoffee from "../assets/external/meeting-coffee.jpg";
import CtaSection from "../components/CtaSection.astro";
import FeatureSection from "../components/FeatureSection.astro";
import HomepageTestimonial from "../components/HomepageTestimonial.astro";
import QuotesSection from "../components/QuotesSection.astro";
import TrustedBy from "../components/TrustedBy.astro";
import {
  HOME_ABOUT_US,
  HOME_SOLUTIONS_EXPERTISE,
  HOME_TESTIMONIAL,
  QUOTES,
  ROUTES,
  TRUSTED_ORGS,
  WE_CAN_HELP,
  WHY_CHOOSE_US,
} from "../consts";
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Home">
  <FeatureSection
    eyebrow={HOME_ABOUT_US.eyebrow}
    title={HOME_ABOUT_US.title}
    paragraphs={HOME_ABOUT_US.paragraphs}
    imageSrc={meetingCoffee}
    imageAlt="Team meeting"
    muted={true}
    level={1}
  />

  <FeatureSection
    eyebrow={HOME_SOLUTIONS_EXPERTISE.eyebrow}
    title={HOME_SOLUTIONS_EXPERTISE.title}
    paragraphs={HOME_SOLUTIONS_EXPERTISE.paragraphs}
    imageSrc={marketingStrategy}
    imageAlt="Strategy and planning"
    reverse={true}
  />

  <FeatureSection
    eyebrow={WHY_CHOOSE_US.eyebrow}
    title={WHY_CHOOSE_US.title}
    paragraphs={WHY_CHOOSE_US.paragraphs}
    primaryLabel="Contact Us"
    primaryHref={ROUTES.CONTACT}
    secondaryLabel="Our Solutions"
    secondaryHref={ROUTES.SOLUTIONS}
    muted={true}
  />

  <QuotesSection quotes={QUOTES} />

  <TrustedBy orgs={TRUSTED_ORGS} />

  <HomepageTestimonial
    quote={HOME_TESTIMONIAL.quote}
    author={HOME_TESTIMONIAL.author}
    role={HOME_TESTIMONIAL.role}
  />

  <CtaSection
    title={WE_CAN_HELP.title}
    description={WE_CAN_HELP.description}
    primaryLabel={WE_CAN_HELP.primaryLabel}
    primaryHref={ROUTES.CONTACT}
  />
</MainLayout>
