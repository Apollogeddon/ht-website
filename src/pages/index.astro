---
import { getCollection } from "astro:content";
import CtaSection from "../components/CtaSection.astro";
import FeatureSection from "../components/FeatureSection.astro";
import Hero from "../components/Hero.astro";
import LatestPosts from "../components/LatestPosts.astro";
import ProcessSteps from "../components/ProcessSteps.astro";
import QuotesSection from "../components/QuotesSection.astro";
import ServiceGrid from "../components/ServiceGrid.astro";
import StatsBand from "../components/StatsBand.astro";
import {
  HERO_CONTENT,
  HOME_CONTENT,
  HOME_CTA,
  HOME_SERVICES,
  PROCESS_STEPS,
  QUOTES,
  ROUTES,
  STATS,
  WHY_CHOOSE_US,
} from "../consts";
import MainLayout from "../layouts/MainLayout.astro";

const recentPosts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---

<MainLayout title="Home">
  <Hero
    eyebrow={HERO_CONTENT.eyebrow}
    title={HERO_CONTENT.title}
    titleHighlight={HERO_CONTENT.titleHighlight}
    description={HERO_CONTENT.description}
    primaryButtonText={HERO_CONTENT.primaryButton}
    secondaryButtonText={HERO_CONTENT.secondaryButton}
  />

  <StatsBand stats={STATS} />

  <FeatureSection
    eyebrow={WHY_CHOOSE_US.eyebrow}
    title={WHY_CHOOSE_US.title}
    paragraphs={WHY_CHOOSE_US.paragraphs}
    quote={WHY_CHOOSE_US.quote}
  />

  <QuotesSection quotes={QUOTES} />

  <ServiceGrid
    eyebrow={HOME_CONTENT.howWeHelpEyebrow}
    title={HOME_CONTENT.howWeHelp}
    services={HOME_SERVICES}
  />

  <ProcessSteps eyebrow={HOME_CONTENT.processEyebrow} title={HOME_CONTENT.processTitle} steps={PROCESS_STEPS} />

  <LatestPosts posts={recentPosts} />

  <CtaSection
    title={HOME_CTA.title}
    description={HOME_CTA.description}
    primaryLabel={HOME_CTA.primaryLabel}
    primaryHref={ROUTES.CONTACT}
    secondaryLabel={HOME_CTA.secondaryLabel}
    secondaryHref={ROUTES.SOLUTIONS}
  />
</MainLayout>
