---
import CtaSection from "../components/CtaSection.astro";
import { ROUTES } from "../consts";
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="section-padding min-h-[60vh] flex items-center">
    <div class="container-site text-center">
      <p class="eyebrow mb-4">404</p>
      <h1 class="text-4xl lg:text-5xl font-extrabold text-[var(--text-primary)] mb-6">Page not found</h1>
      <p class="text-lg text-[var(--text-secondary)] max-w-md mx-auto mb-10">
        The page you're looking for doesn't exist or may have been moved.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={ROUTES.HOME} class="btn-primary">Go home</a>
        <a href={ROUTES.CONTACT} class="btn-secondary">Contact us</a>
      </div>
    </div>
  </div>
</MainLayout>
