---
import pexelsPhoto from "../assets/external/pexels-photo.jpg";
import CtaSection from "../components/CtaSection.astro";
import FeatureSection from "../components/FeatureSection.astro";
import SolutionCard from "../components/SolutionCard.astro";
import { ROUTES, SOLUTIONS, SOLUTIONS_CONTENT, SOLUTIONS_INTRO, WE_CAN_HELP } from "../consts";
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title={SOLUTIONS_CONTENT.title}>
  <FeatureSection
    title={SOLUTIONS_CONTENT.title}
    paragraphs={[SOLUTIONS_INTRO]}
    imageSrc={pexelsPhoto}
    imageAlt="Professional workspace"
    level={1}
    muted={true}
  />

  <div class="section-padding">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        {
          SOLUTIONS.map((item, i) => (
            <SolutionCard
              title={item.title}
              description={item.description}
              features={item.features}
              index={i}
              href={`${ROUTES.SOLUTIONS}/${item.slug}`}
            />
          ))
        }
      </div>
    </div>
  </div>

  <CtaSection
    title={WE_CAN_HELP.title}
    description={WE_CAN_HELP.description}
    primaryLabel={WE_CAN_HELP.primaryLabel}
    primaryHref={ROUTES.CONTACT}
  />
</MainLayout>
