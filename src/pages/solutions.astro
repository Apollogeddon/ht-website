---
import CtaSection from "../components/CtaSection.astro";
import SectionHeading from "../components/SectionHeading.astro";
import SolutionCard from "../components/SolutionCard.astro";
import { ROUTES, SOLUTIONS, SOLUTIONS_CONTENT, SOLUTIONS_CTA, SOLUTIONS_INTRO } from "../consts";
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title={SOLUTIONS_CONTENT.title}>
  <div class="section-padding">
    <div class="container-site">
      <div class="mb-12 text-center">
        <SectionHeading
          eyebrow={SOLUTIONS_CONTENT.eyebrow}
          title={SOLUTIONS_CONTENT.title}
          description={SOLUTIONS_INTRO}
          align="center"
          level={1}
        />
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        {
          SOLUTIONS.map((item, i) => (
            <SolutionCard
              title={item.title}
              description={item.description}
              features={item.features}
              index={i}
            />
          ))
        }
      </div>
    </div>
  </div>

  <CtaSection
    title={SOLUTIONS_CTA.title}
    description={SOLUTIONS_CTA.description}
    primaryLabel={SOLUTIONS_CTA.primaryLabel}
    primaryHref={ROUTES.CONTACT}
  />
</MainLayout>
