---
import { getCollection, render } from "astro:content";
import CtaSection from "../components/CtaSection.astro";
import SectionHeading from "../components/SectionHeading.astro";
import StatsBand from "../components/StatsBand.astro";
import TestimonialCarousel from "../components/TestimonialCarousel.astro";
import { ROUTES, STATS, TESTIMONIALS_CONTENT, TESTIMONIALS_CTA } from "../consts";
import MainLayout from "../layouts/MainLayout.astro";

const testimonialsEntries = await getCollection("testimonials");

const testimonialData = testimonialsEntries.map((entry) => ({
  author: entry.data.author,
  role: entry.data.role,
  body: entry.body?.trim().replace(/^"|"$/g, "") || "",
}));
---

<MainLayout title={TESTIMONIALS_CONTENT.title}>
  <div class="section-padding">
    <div class="container-site">
      <div class="mb-12 text-center">
        <SectionHeading
          eyebrow={TESTIMONIALS_CONTENT.eyebrow}
          title={TESTIMONIALS_CONTENT.title}
          description={TESTIMONIALS_CONTENT.description}
          align="center"
        />
      </div>

      <TestimonialCarousel testimonials={testimonialData} />
    </div>
  </div>

  <StatsBand stats={STATS} />

  <CtaSection
    title={TESTIMONIALS_CTA.title}
    description={TESTIMONIALS_CTA.description}
    primaryLabel={TESTIMONIALS_CTA.primaryLabel}
    primaryHref={ROUTES.CONTACT}
    secondaryLabel={TESTIMONIALS_CTA.secondaryLabel}
    secondaryHref={ROUTES.SOLUTIONS}
  />
</MainLayout>
