---
import { getCollection } from "astro:content";
import { BLOG_CONTENT, DATE_LOCALE, DATE_OPTIONS, ROUTES, UI_LABELS } from "../../consts";
import MainLayout from "../../layouts/MainLayout.astro";
import { ICONS } from "../../styles";

const posts = (await getCollection("blog")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<MainLayout title="Blog">
  <div class="section-padding">
    <div class="container-site">
      <div class="max-w-5xl mx-auto">

        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-12 gap-6">
          <h1 class="text-4xl font-extrabold text-[var(--text-primary)] leading-tight">{BLOG_CONTENT.title}</h1>

          <div class="relative w-full md:w-64">
            <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
              <svg class="w-4 h-4 text-[var(--text-secondary)]" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 20">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={ICONS.search} />
              </svg>
            </div>
            <input
              type="text"
              id="search-input"
              class="w-full px-4 py-3 pl-10 rounded-lg border border-[var(--border-strong)] bg-[var(--bg-secondary)] text-[var(--text-primary)] outline-none transition-all focus:border-[var(--brand-accent)]"
              placeholder={BLOG_CONTENT.searchPlaceholder}
            />
          </div>
        </div>

        <div id="posts-container" class="space-y-6">
          {
            posts.map((post) => (
              <article
                class="group post-item card-interactive p-8"
                data-title={post.data.title.toLowerCase()}
                data-desc={post.data.description.toLowerCase()}
              >
                <a href={`${ROUTES.BLOG}/${post.id}`} class="block">
                  <p class="text-sm text-[var(--text-secondary)] opacity-80 mb-2">
                    {post.data.pubDate.toLocaleDateString(DATE_LOCALE, DATE_OPTIONS)}
                  </p>
                  <h2
                    class="text-2xl font-bold text-[var(--text-primary)] group-hover:text-[var(--brand-accent)] transition-colors mb-4"
                    transition:name={`title-${post.id}`}
                  >
                    {post.data.title}
                  </h2>
                  <p class="text-[var(--text-secondary)] leading-relaxed mb-6">
                    {post.data.description}
                  </p>
                  <span class="text-[var(--brand-accent)] font-bold flex items-center gap-1 group-hover:gap-2 transition-all">
                    {UI_LABELS.readMore}
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={ICONS.arrowRight} />
                    </svg>
                  </span>
                </a>
              </article>
            ))
          }
        </div>

        <p id="no-results" class="hidden text-center text-[var(--text-secondary)] mt-8 text-lg">
          {BLOG_CONTENT.noResults}
        </p>

      </div>
    </div>
  </div>
</MainLayout>

<script>
  const initSearch = () => {
    const searchInput = document.getElementById('search-input');
    const noResultsMsg = document.getElementById('no-results');
    const posts = document.querySelectorAll('.post-item');

    if (!searchInput) return;

    searchInput.addEventListener('input', (e) => {
      const term = (e.target as HTMLInputElement).value.toLowerCase();
      let hasResults = false;

      posts.forEach((post) => {
        const title = (post as HTMLElement).dataset.title || '';
        const desc = (post as HTMLElement).dataset.desc || '';

        if (title.includes(term) || desc.includes(term)) {
          post.classList.remove('hidden');
          hasResults = true;
        } else {
          post.classList.add('hidden');
        }
      });

      if (hasResults) {
        noResultsMsg?.classList.add('hidden');
      } else {
        noResultsMsg?.classList.remove('hidden');
      }
    });
  };

  document.addEventListener('astro:page-load', initSearch);
</script>
