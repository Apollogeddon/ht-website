---
import { Image } from "astro:assets";
import adelaideRiver from "../assets/external/adelaide-river-torrens.jpg";
import tinaHudson from "../assets/external/tina-hudson.jpg";
import Avatar from "../components/Avatar.astro";
import CtaSection from "../components/CtaSection.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { PRINCIPAL_CONSULTANT, ROUTES, WE_CAN_HELP } from "../consts";
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Our Profiles">
  <div class="relative h-56 md:h-72 overflow-hidden">
    <Image
      src={adelaideRiver}
      alt="Adelaide River Torrens"
      class="w-full h-full object-cover object-center"
      widths={[640, 1280, 1920]}
      sizes="100vw"
    />
    <div class="absolute inset-0 bg-[var(--bg-inverse)] opacity-30"></div>
  </div>

  <section class="section-padding bg-[var(--bg-muted)] scroll-reveal">
    <div class="container-site">
      <div class="max-w-5xl mx-auto">
        <SectionHeading eyebrow="Our Team" title="Our Profiles" level={1} />
        <div class="mt-10 flex flex-col md:flex-row gap-10 items-center md:items-start">
          <div class="flex-shrink-0">
            <Avatar
              name={PRINCIPAL_CONSULTANT.name}
              role={PRINCIPAL_CONSULTANT.role}
              src={tinaHudson}
              size="lg"
            />
          </div>
          <div class="flex-grow">
            <p class="text-lg text-[var(--text-secondary)] leading-relaxed">
              {PRINCIPAL_CONSULTANT.bio}
            </p>
            {PRINCIPAL_CONSULTANT.linkedin && (
              <a
                href={PRINCIPAL_CONSULTANT.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 mt-5 text-sm font-semibold text-[var(--brand-accent)] hover:underline"
              >
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                </svg>
                View LinkedIn Profile
              </a>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaSection
    title={WE_CAN_HELP.title}
    description={WE_CAN_HELP.description}
    primaryLabel={WE_CAN_HELP.primaryLabel}
    primaryHref={ROUTES.CONTACT}
  />
</MainLayout>
