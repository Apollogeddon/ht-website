---
import { Image } from "astro:assets";
import adelaideNorthTerrace from "../assets/external/adelaide-north-terrace.jpg";
import { CONTACT_INFO, CONTACT_PAGE } from "../consts";
import MainLayout from "../layouts/MainLayout.astro";
import { ICONS } from "../styles";

const contactDetails = [
  { label: CONTACT_PAGE.labels.email, value: CONTACT_INFO.email, icon: "email" },
  { label: CONTACT_PAGE.labels.phone, value: CONTACT_INFO.phone, icon: "phone" },
  { label: CONTACT_PAGE.labels.location, value: CONTACT_INFO.location_full, icon: "location" },
];
---

<MainLayout title={CONTACT_PAGE.title}>
  <div class="relative h-52 md:h-64 overflow-hidden">
    <Image
      src={adelaideNorthTerrace}
      alt="Adelaide North Terrace"
      class="w-full h-full object-cover object-center"
      widths={[640, 1280, 1920]}
      sizes="100vw"
    />
    <div class="absolute inset-0 bg-[var(--bg-inverse)] opacity-40"></div>
  </div>

  <div class="section-padding">
    <div class="container-custom">
      <div class="max-w-5xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-20">
          <!-- Contact Info -->
          <div>
            <h1 class="text-4xl lg:text-5xl font-bold text-[var(--text-primary)] mb-6 leading-tight">
              {CONTACT_PAGE.title}
            </h1>
            <p class="text-lg text-[var(--text-secondary)] mb-12 max-w-md">
              {CONTACT_PAGE.subtitle}
            </p>

            <div class="space-y-8">
              {
                contactDetails.map((item) => (
                  <div class="flex gap-5">
                    <div class="w-12 h-12 rounded-xl bg-[var(--brand-light)] flex items-center justify-center shrink-0">
                      <svg
                        class="w-6 h-6 text-[var(--brand-accent)]"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        aria-hidden="true"
                      >
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={ICONS[item.icon as keyof typeof ICONS]} />
                      </svg>
                    </div>
                    <div>
                      <h2 class="font-bold text-[var(--text-primary)] mb-1">{item.label}</h2>
                      <p class="text-[var(--text-secondary)]">{item.value}</p>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>

          <!-- Contact Form -->
          <div class="bg-[var(--bg-secondary)] rounded-2xl p-8 lg:p-10 border border-[var(--border-strong)] shadow-sm">
            <form id="contact-form" class="space-y-4">
              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label for="first-name" class="block text-sm font-medium text-[var(--text-secondary)] mb-1">{CONTACT_PAGE.form.firstName}</label>
                  <input
                    type="text"
                    id="first-name"
                    name="firstName"
                    class="w-full px-4 py-3 rounded-lg border border-[var(--border-strong)] bg-[var(--bg-secondary)] text-[var(--text-primary)] outline-none transition-all focus:border-[var(--brand-accent)]"
                    style="box-shadow: none;"
                    onfocus="this.style.boxShadow='var(--ring-focus)'"
                    onblur="this.style.boxShadow='none'"
                    required
                  />
                </div>
                <div>
                  <label for="last-name" class="block text-sm font-medium text-[var(--text-secondary)] mb-1">{CONTACT_PAGE.form.lastName}</label>
                  <input
                    type="text"
                    id="last-name"
                    name="lastName"
                    class="w-full px-4 py-3 rounded-lg border border-[var(--border-strong)] bg-[var(--bg-secondary)] text-[var(--text-primary)] outline-none transition-all focus:border-[var(--brand-accent)]"
                    style="box-shadow: none;"
                    onfocus="this.style.boxShadow='var(--ring-focus)'"
                    onblur="this.style.boxShadow='none'"
                    required
                  />
                </div>
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-[var(--text-secondary)] mb-1">{CONTACT_PAGE.form.email}</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  class="w-full px-4 py-3 rounded-lg border border-[var(--border-strong)] bg-[var(--bg-secondary)] text-[var(--text-primary)] outline-none transition-all focus:border-[var(--brand-accent)]"
                  style="box-shadow: none;"
                  onfocus="this.style.boxShadow='var(--ring-focus)'"
                  onblur="this.style.boxShadow='none'"
                  required
                />
              </div>
              <div>
                <label for="message" class="block text-sm font-medium text-[var(--text-secondary)] mb-1">{CONTACT_PAGE.form.message}</label>
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  class="w-full px-4 py-3 rounded-lg border border-[var(--border-strong)] bg-[var(--bg-secondary)] text-[var(--text-primary)] outline-none transition-all focus:border-[var(--brand-accent)]"
                  style="box-shadow: none;"
                  onfocus="this.style.boxShadow='var(--ring-focus)'"
                  onblur="this.style.boxShadow='none'"
                  required
                ></textarea>
              </div>
              <div id="form-message" class="hidden rounded-lg p-4 text-sm font-bold"></div>
              <button
                type="submit"
                id="submit-btn"
                class="btn-primary w-full justify-center disabled:opacity-50 disabled:cursor-not-allowed"
              >
                {CONTACT_PAGE.form.submit}
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  const initContactForm = () => {
    const form = document.getElementById("contact-form") as HTMLFormElement;
    const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
    const formMessage = document.getElementById("form-message");

    if (!form || !submitBtn || !formMessage) return;
    if (form.dataset.initialized === "true") return;

    form.dataset.initialized = "true";

    const WORKER_URL = import.meta.env.PUBLIC_CONTACT_WORKER_URL || "https://ht-contact-api.your-subdomain.workers.dev";

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      submitBtn.disabled = true;
      const originalBtnText = submitBtn.textContent;
      submitBtn.textContent = "Sending...";
      formMessage.classList.add("hidden");

      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());

      try {
        const response = await fetch(WORKER_URL, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(data),
        });

        const result = await response.json();

        if (response.ok) {
          formMessage.textContent = result.message || "Thank you! Your message has been sent successfully.";
          formMessage.classList.remove("hidden", "bg-red-100", "text-red-700", "border-red-200");
          formMessage.classList.add("bg-green-100", "text-green-700", "border-green-200", "border");
          form.reset();
        } else {
          throw new Error(result.message || result.error || "Something went wrong.");
        }
      } catch (err: any) {
        formMessage.textContent = err.message || "Failed to send message. Please try again later.";
        formMessage.classList.remove("hidden", "bg-green-100", "text-green-700", "border-green-200");
        formMessage.classList.add("bg-red-100", "text-red-700", "border-red-200", "border");
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = originalBtnText;
      }
    });
  };

  initContactForm();
  document.addEventListener("astro:page-load", initContactForm);
</script>
