---
import { CONTACT_INFO, CONTACT_PAGE } from "../consts";
import MainLayout from "../layouts/MainLayout.astro";
import { ICONS } from "../styles";
---

<MainLayout title={CONTACT_PAGE.title}>
  <div class="section-padding">
    <div class="container-site">
      <div class="max-w-5xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

          <div>
            <h1 class="text-4xl font-extrabold text-[var(--text-primary)] leading-tight mb-6">{CONTACT_PAGE.title}</h1>
            <p class="text-xl text-[var(--text-secondary)] leading-relaxed mb-12">
              {CONTACT_PAGE.subtitle}
            </p>

            <div class="card-base card-grid-pattern p-8 space-y-8">
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-[var(--brand-light)] rounded-full flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[var(--brand-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={ICONS.mail} />
                  </svg>
                </div>
                <div>
                  <h2 class="text-xl font-bold text-[var(--text-primary)] mb-1">{CONTACT_PAGE.labels.email}</h2>
                  <a href={`mailto:${CONTACT_INFO.email}`} class="text-[var(--brand-accent)] hover:text-[var(--brand-accent-hover)] hover:underline transition-colors">{CONTACT_INFO.email}</a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-[var(--brand-light)] rounded-full flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[var(--brand-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={ICONS.phone} />
                  </svg>
                </div>
                <div>
                  <h2 class="text-xl font-bold text-[var(--text-primary)] mb-1">{CONTACT_PAGE.labels.phone}</h2>
                  <a href={`tel:${CONTACT_INFO.phone.replace(/\s+/g, '')}`} class="text-[var(--brand-accent)] hover:text-[var(--brand-accent-hover)] hover:underline transition-colors">{CONTACT_INFO.phone}</a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-[var(--brand-light)] rounded-full flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[var(--brand-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={ICONS.location} />
                  </svg>
                </div>
                <div>
                  <h2 class="text-xl font-bold text-[var(--text-primary)] mb-1">{CONTACT_PAGE.labels.location}</h2>
                  <p class="text-[var(--text-secondary)]">{CONTACT_INFO.location_full}</p>
                </div>
              </div>
            </div>
          </div>

          <div class="card-base p-10">
            <form id="contact-form" class="space-y-4">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label for="first-name" class="block text-sm font-medium text-[var(--text-secondary)] mb-1">{CONTACT_PAGE.form.firstName}</label>
                  <input
                    type="text"
                    id="first-name"
                    name="firstName"
                    class="w-full px-4 py-3 rounded-lg border border-[var(--border-strong)] bg-[var(--bg-secondary)] text-[var(--text-primary)] outline-none transition-all focus:border-[var(--brand-accent)]"
                    style="box-shadow: none;"
                    onfocus="this.style.boxShadow='var(--ring-focus)'"
                    onblur="this.style.boxShadow='none'"
                    required
                  />
                </div>
                <div>
                  <label for="last-name" class="block text-sm font-medium text-[var(--text-secondary)] mb-1">{CONTACT_PAGE.form.lastName}</label>
                  <input
                    type="text"
                    id="last-name"
                    name="lastName"
                    class="w-full px-4 py-3 rounded-lg border border-[var(--border-strong)] bg-[var(--bg-secondary)] text-[var(--text-primary)] outline-none transition-all focus:border-[var(--brand-accent)]"
                    style="box-shadow: none;"
                    onfocus="this.style.boxShadow='var(--ring-focus)'"
                    onblur="this.style.boxShadow='none'"
                    required
                  />
                </div>
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-[var(--text-secondary)] mb-1">{CONTACT_PAGE.form.email}</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  class="w-full px-4 py-3 rounded-lg border border-[var(--border-strong)] bg-[var(--bg-secondary)] text-[var(--text-primary)] outline-none transition-all focus:border-[var(--brand-accent)]"
                  style="box-shadow: none;"
                  onfocus="this.style.boxShadow='var(--ring-focus)'"
                  onblur="this.style.boxShadow='none'"
                  required
                />
              </div>
              <div>
                <label for="message" class="block text-sm font-medium text-[var(--text-secondary)] mb-1">{CONTACT_PAGE.form.message}</label>
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  class="w-full px-4 py-3 rounded-lg border border-[var(--border-strong)] bg-[var(--bg-secondary)] text-[var(--text-primary)] outline-none transition-all focus:border-[var(--brand-accent)]"
                  style="box-shadow: none;"
                  onfocus="this.style.boxShadow='var(--ring-focus)'"
                  onblur="this.style.boxShadow='none'"
                  required
                ></textarea>
              </div>
              <div id="form-message" class="hidden rounded-lg p-4 text-sm font-bold"></div>
              <button
                type="submit"
                id="submit-btn"
                class="btn-primary w-full justify-center disabled:opacity-50 disabled:cursor-not-allowed"
              >
                {CONTACT_PAGE.form.submit}
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</MainLayout>
