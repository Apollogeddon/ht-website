---
import Avatar from "../components/Avatar.astro";
import CtaSection from "../components/CtaSection.astro";
import FeatureSection from "../components/FeatureSection.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { ABOUT_CONTENT, ABOUT_CTA, COMPANY_OVERVIEW, COMPANY_VALUES, PRINCIPAL_CONSULTANT, ROUTES } from "../consts";
import MainLayout from "../layouts/MainLayout.astro";
import { ICONS } from "../styles";
---

<MainLayout title={ABOUT_CONTENT.title}>
  <Hero
    title={ABOUT_CONTENT.title}
    description={ABOUT_CONTENT.intro}
    primaryButtonText={ABOUT_CONTENT.primaryButton}
    secondaryButtonText={ABOUT_CONTENT.secondaryButton}
  />

  <section class="section-padding bg-[var(--bg-muted)] scroll-reveal">
    <div class="container-site">
      <div class="max-w-5xl mx-auto">
        <SectionHeading eyebrow={COMPANY_OVERVIEW.eyebrow} title={COMPANY_OVERVIEW.title} />
        <p class="text-lg text-[var(--text-secondary)] leading-relaxed mb-10 mt-6">
          {COMPANY_OVERVIEW.description}
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-6">
          {
            COMPANY_OVERVIEW.points.map((point) => (
              <div class="flex items-start gap-3">
                <div class="mt-1 bg-[var(--brand-light)] p-1 rounded-full flex-shrink-0">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-4 w-4 text-[var(--brand-accent)]"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                  >
                    <path fill-rule="evenodd" d={ICONS.check} clip-rule="evenodd" />
                  </svg>
                </div>
                <span class="text-[var(--text-primary)] leading-tight font-medium">{point}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <FeatureSection
    eyebrow={ABOUT_CONTENT.valuesEyebrow}
    title={ABOUT_CONTENT.valuesTitle}
    paragraphs={[]}
  />

  <section class="section-padding bg-[var(--bg-secondary)] scroll-reveal">
    <div class="container-site">
      <div class="max-w-5xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {
            COMPANY_VALUES.map((value, i) => (
              <div class="card-base p-8 scroll-reveal" style={`--delay: ${i * 100}ms`}>
                <div class="h-1 w-12 bg-brand-gradient rounded-full mb-5"></div>
                <h3 class="text-xl font-bold text-[var(--text-primary)] mb-3">{value.title}</h3>
                <p class="text-[var(--text-secondary)] italic text-sm leading-relaxed">{value.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-[var(--bg-muted)] scroll-reveal">
    <div class="container-site">
      <div class="max-w-5xl mx-auto">
        <SectionHeading eyebrow={ABOUT_CONTENT.profilesEyebrow} title={ABOUT_CONTENT.profilesTitle} />
        <div class="mt-10 flex flex-col md:flex-row gap-10 items-center md:items-start">
          <div class="flex-shrink-0">
            <Avatar
              name={PRINCIPAL_CONSULTANT.name}
              role={PRINCIPAL_CONSULTANT.role}
              size="lg"
            />
          </div>
          <div class="flex-grow">
            <p class="text-lg text-[var(--text-secondary)] leading-relaxed">
              {PRINCIPAL_CONSULTANT.bio}
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaSection
    title={ABOUT_CTA.title}
    description={ABOUT_CTA.description}
    primaryLabel={ABOUT_CTA.primaryLabel}
    primaryHref={ROUTES.CONTACT}
    secondaryLabel={ABOUT_CTA.secondaryLabel}
    secondaryHref={ROUTES.SOLUTIONS}
  />
</MainLayout>
